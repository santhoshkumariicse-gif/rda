PORT=5000
NODE_ENV=development

# Prisma / PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/lorrybook
DIRECT_URL=postgresql://user:password@localhost:5432/lorrybook

# JWT
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Admin seed
ADMIN_EMAIL=admin@lorrybook.com
ADMIN_PASSWORD=ChangeMe123!

# Frontend / CORS
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:3000

# OAuth / Payments / AI
GOOGLE_CLIENT_ID=your-google-oauth-client-id
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
GEMINI_API_KEY=your-gemini-api-key

# Email (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

USE_HTTPS=false
